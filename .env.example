# ============================================================
#  Doko · Variables de entorno
#  Copia este archivo a .env.local y rellena con tus valores.
#  (.env.local NO se sube al repo.)
# ============================================================

# ---------- Supabase ----------
# Dashboard → Project Settings → API
# URL del proyecto y clave pública (segura para el navegador):
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave service_role (SECRETA · solo server-side · omite RLS).
# NO le pongas el prefijo NEXT_PUBLIC ni la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------- Backend Laravel (opcional / legacy) ----------
# Si algún día usas un API de Laravel en vez de Supabase, define esto
# y lib/api.ts le pegará a ese API (ver el fallback en el código).
# NEXT_PUBLIC_API_URL=https://api.doko.pe
